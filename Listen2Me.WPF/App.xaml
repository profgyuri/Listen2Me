<Application x:Class="Listen2Me.WPF.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:exampleViewModels="clr-namespace:Listen2Me.WPF.Modules.Example"
             xmlns:viewModels="clr-namespace:Listen2Me.MVVM.ViewModels;assembly=Listen2Me.MVVM"
             xmlns:views="clr-namespace:Listen2Me.WPF.Views">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:CustomColorTheme BaseTheme="Light" PrimaryColor="DarkSlateBlue" SecondaryColor="Lime" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <DataTemplate DataType="{x:Type viewModels:DefaultHomeViewModel}">
                <views:DefaultHomeView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type exampleViewModels:ExampleModuleViewModel}">
                <views:ExampleModuleView />
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>

