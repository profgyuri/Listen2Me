<Application x:Class="Listen2Me.WPF.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:layouts="clr-namespace:Listen2Me.WPF.Views.Layouts"
             xmlns:layoutVm="clr-namespace:Listen2Me.MVVM.ViewModels.Layouts;assembly=Listen2Me.MVVM"
             xmlns:widgetVm="clr-namespace:Listen2Me.MVVM.ViewModels.Widgets;assembly=Listen2Me.MVVM"
             xmlns:widgets="clr-namespace:Listen2Me.WPF.Views.Widgets"
             xmlns:settingsTabVm="clr-namespace:Listen2Me.MVVM.ViewModels.Tabs.Settings;assembly=Listen2Me.MVVM"
             xmlns:settingsTabs="clr-namespace:Listen2Me.WPF.Views.Tabs.Settings">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- For some reason, nested resources only load at startup and don't change during runtime.
                     This approach is still perfectly valid for value converters and style collections,
                     but style files that can be substituted have to be referenced directly here. -->
                <materialDesign:CustomColorTheme BaseTheme="Light" PrimaryColor="DarkSlateBlue" SecondaryColor="Lime" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />
                <ResourceDictionary Source="Styles/Themes/Light.xaml"/>
                <ResourceDictionary Source="Styles/Themes/Accent.Blue.xaml"/>
                <ResourceDictionary Source="Styles/StyleDictionary.xaml"/>
                <ResourceDictionary Source="Styles/ValueConverterDictionary.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            
            <DataTemplate DataType="{x:Type layoutVm:MainLayoutViewModel}">
                <layouts:DefaultMainLayout />
            </DataTemplate>
            <DataTemplate DataType="{x:Type layoutVm:SettingsLayoutViewModel}">
                <layouts:SettingsLayout/>
            </DataTemplate>
            
            <DataTemplate DataType="{x:Type settingsTabVm:AppearanceTabViewModel}">
                <settingsTabs:AppearanceTab/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type settingsTabVm:GeneralTabViewModel}">
                <settingsTabs:GeneralTab/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type settingsTabVm:LibraryTabViewModel}">
                <settingsTabs:LibraryTab/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type settingsTabVm:PlaybackTabViewModel}">
                <settingsTabs:PlaybackTab/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type settingsTabVm:StorageTabViewModel}">
                <settingsTabs:StorageTab/>
            </DataTemplate>
            
            <DataTemplate DataType="{x:Type widgetVm:PlayerControlsWidgetViewModel}">
                <widgets:PlayerControlsWidget/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type widgetVm:PlaylistWidgetViewModel}">
                <widgets:PlaylistWidget/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type widgetVm:SearchResultsWidgetViewModel}">
                <widgets:SearchResultsWidget/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type widgetVm:TrackInfoWidgetViewModel}">
                <widgets:TrackInfoWidget/>
            </DataTemplate>
            
        </ResourceDictionary>
    </Application.Resources>
</Application>

