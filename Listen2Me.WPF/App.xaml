<Application x:Class="Listen2Me.WPF.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:layouts="clr-namespace:Listen2Me.WPF.Views.Layouts"
             xmlns:layoutVm="clr-namespace:Listen2Me.MVVM.ViewModels.Layouts;assembly=Listen2Me.MVVM"
             xmlns:widgetVm="clr-namespace:Listen2Me.MVVM.ViewModels.Widgets;assembly=Listen2Me.MVVM"
             xmlns:widgets="clr-namespace:Listen2Me.WPF.Views.Widgets"
             xmlns:componentVm="clr-namespace:Listen2Me.MVVM.ViewModels.Components;assembly=Listen2Me.MVVM"
             xmlns:components="clr-namespace:Listen2Me.WPF.Views.Components">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:CustomColorTheme BaseTheme="Light" PrimaryColor="DarkSlateBlue" SecondaryColor="Lime" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />
                <ResourceDictionary Source="Styles/Themes/ThemeDictionary.xaml"/>
                <ResourceDictionary Source="Styles/StyleDictionary.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            
            <DataTemplate DataType="{x:Type layoutVm:MainLayoutViewModel}">
                <layouts:DefaultMainLayout />
            </DataTemplate>
            <DataTemplate DataType="{x:Type layoutVm:SettingsLayoutViewModel}">
                <layouts:SettingsLayout/>
            </DataTemplate>
            
            <DataTemplate DataType="{x:Type widgetVm:PlayerControlsWidgetViewModel}">
                <widgets:PlayerControlsWidget/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type widgetVm:PlaylistWidgetViewModel}">
                <widgets:PlaylistWidget/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type widgetVm:SearchResultsWidgetViewModel}">
                <widgets:SearchResultsWidget/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type widgetVm:TrackInfoWidgetViewModel}">
                <widgets:TrackInfoWidget/>
            </DataTemplate>
            
            <DataTemplate DataType="{x:Type componentVm:NavBarViewModel}">
                <components:NavBar/>
            </DataTemplate>
            
        </ResourceDictionary>
    </Application.Resources>
</Application>

