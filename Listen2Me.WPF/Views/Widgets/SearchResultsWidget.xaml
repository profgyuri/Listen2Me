<UserControl x:Class="Listen2Me.WPF.Views.Widgets.SearchResultsWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Listen2Me.WPF.Views.Widgets"
             xmlns:widgetVm="clr-namespace:Listen2Me.MVVM.ViewModels.Widgets;assembly=Listen2Me.MVVM"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance widgetVm:SearchResultsWidgetViewModel}"
             d:DesignHeight="300" d:DesignWidth="300">
    <Grid>
        <TextBlock Text="{Binding Name}"/>
    </Grid>
</UserControl>
