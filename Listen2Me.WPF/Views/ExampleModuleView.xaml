<UserControl x:Class="Listen2Me.WPF.Views.ExampleModuleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:example="clr-namespace:Listen2Me.WPF.Modules.Example"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance example:ExampleModuleViewModel}">
    <Border Padding="20"
            CornerRadius="8"
            Background="#FFF8FAFC"
            BorderBrush="#33000000"
            BorderThickness="1">
        <StackPanel>
            <TextBlock FontSize="28"
                       FontWeight="Bold"
                       Text="{Binding Title}" />
            <TextBlock Margin="0,10,0,0"
                       FontSize="15"
                       Text="{Binding Status}" />

            <StackPanel Margin="0,14,0,0"
                        Orientation="Horizontal">
                <Button Padding="12,6"
                        Command="{Binding RefreshStatusCommand}"
                        Content="Refresh Status" />
                <Button Margin="8,0,0,0"
                        Padding="12,6"
                        Command="{Binding BroadcastMessageCommand}"
                        Content="Broadcast Message" />
            </StackPanel>

            <TextBlock Margin="0,12,0,0"
                       FontWeight="SemiBold"
                       Text="{Binding BroadcastCount, StringFormat=Broadcast Count: {0}}" />
            <TextBlock Margin="0,4,0,0"
                       Text="{Binding LastReceivedMessage}" />
        </StackPanel>
    </Border>
</UserControl>

