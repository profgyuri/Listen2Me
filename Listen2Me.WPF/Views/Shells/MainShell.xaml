<Window x:Class="Listen2Me.WPF.Views.Shells.MainShell"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:shells="clr-namespace:Listen2Me.MVVM.ViewModels.Shells;assembly=Listen2Me.MVVM"
        xmlns:components="clr-namespace:Listen2Me.WPF.Views.Components"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance shells:MainShellViewModel}"
        Background="{DynamicResource Brush.Background.Primary}"
        Foreground="{DynamicResource Brush.Foreground.Primary}"
        Title="MainWindow" Height="450" Width="800" BorderThickness="0"
        WindowStyle="None" WindowState="{Binding WindowState}"
        FontFamily="{Binding FontFamily}" FontSize="{Binding FontSize}"
        FontWeight="{Binding IsBold, Converter={StaticResource BoolToBoldConverter}}"
        FontStyle="{Binding IsItalic, Converter={StaticResource BoolToItalicConverter}}">
    
    <WindowChrome.WindowChrome>
        <WindowChrome x:Name="WindowChrome" CaptionHeight="32" />
    </WindowChrome.WindowChrome>
    
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="{Binding ElementName=WindowChrome, Path=CaptionHeight}"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <components:TitleBar Grid.Row="0"/>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
        
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <components:NavBar Grid.Row="0">
                    <components:NavBarItem Icon="MusicNote" Text="Player"
                                           IsActive="{Binding CurrentRoute, Converter={StaticResource PathComparer}, ConverterParameter=home}"
                                           Command="{Binding NavigateCommand}" CommandParameter="home"/>
                    <components:NavBarItem Icon="Gear" Text="Settings" 
                                           IsActive="{Binding CurrentRoute, Converter={StaticResource PathComparer}, ConverterParameter=settings}"
                                           Command="{Binding NavigateCommand}" CommandParameter="settings"/>
                </components:NavBar>
                <components:NavBar Grid.Row="2">
                    <components:NavBarItem Icon="DoorOpen" Text="Close" 
                                           Command="{Binding CloseCommand}"/>
                </components:NavBar>
            </Grid>
            <ContentControl Grid.Column="1" Content="{Binding CurrentViewModel}"/>
        </Grid>
    </Grid>
</Window>
